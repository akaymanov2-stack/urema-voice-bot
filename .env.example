# ===== Telegram =====
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Разрешённые user_id через запятую (узнать свой — @userinfobot)
ALLOWED_USER_IDS=12345678
# Канал uRema: @username или числовой id (-100...)
CHANNEL_ID=@urema_channel

# ===== Supabase (прямой доступ к БД блога) =====
SUPABASE_URL=https://xxxxxxxx.supabase.co
# service_role ключ (Project Settings → API → service_role). СЕКРЕТ, полный доступ к БД!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ===== Блог uRema =====
SITE_URL=https://i-home-indol.vercel.app
BLOG_AUTHOR_NAME=uRema
# Опционально: identifier пользователя из таблицы users (чтобы проставить author_id)
BLOG_AUTHOR_IDENTIFIER=
BLOG_CATEGORY_NAME=uRema
BLOG_CATEGORY_SLUG=urema
STORAGE_BUCKET=blog-images
PLACEHOLDER_PATH=assets/placeholder.png
PLACEHOLDER_STORAGE_PATH=images/urema-placeholder.png
TITLE_DATE_FORMAT=%d.%m.%Y

# ===== STT (faster-whisper) =====
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=ru

# ===== Сообщения =====
CHANNEL_MESSAGE=Текст размещён
